{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "framework": "nextjs",
  "buildCommand": "prisma generate && next build",
  "devCommand": "next dev",
  "installCommand": "npm install",
  "regions": ["fra1"],
  "env": {
    "NEXT_PUBLIC_APP_URL": "https://akgolf.no"
  },
  "crons": [
    {
      "path": "/api/portal/cron/send-reminders",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/send-reminders",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/cleanup-notifications",
      "schedule": "0 2 * * 0"
    },
    {
      "path": "/api/portal/cron/reset-monthly-sessions",
      "schedule": "5 0 * * *"
    },
    {
      "path": "/api/portal/cron/reconcile-stripe-bookings",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/portal/cron/session-expiry-reminder",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/portal/cron/weekly-summary",
      "schedule": "0 18 * * 0"
    },
    {
      "path": "/api/portal/cron/win-back",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/portal/cron/welcome-sequence",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/portal/cron/abandoned-checkout",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/portal/cron/ai-insights",
      "schedule": "0 6 * * 1"
    },
    {
      "path": "/api/portal/cron/compute-usi",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/portal/cron/auto-adjust-training-plans",
      "schedule": "30 3 * * *"
    },
    {
      "path": "/api/cron/coaching-forecast-backtest",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/cleanup-pending-bookings",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/release-dropin-slots",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/smart-notifications",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/charge-completed",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/mark-no-shows",
      "schedule": "30 * * * *"
    },
    {
      "path": "/api/cron/sync-google-calendars",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/cleanup-waitlist",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/portal/tournament-planner/sync",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/portal/cron/process-coaching-audio",
      "schedule": "*/15 * * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/portal/public/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type"
        }
      ]
    },
    {
      "source": "/api/health",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}
