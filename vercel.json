{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/portal/cron/send-reminders",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/portal/cron/reset-monthly-sessions",
      "schedule": "5 0 * * *"
    },
    {
      "path": "/api/portal/cron/session-expiry-reminder",
      "schedule": "0 9 * * *"
    }
  ],
  "env": {
    "NEXTAUTH_URL": "${VERCEL_URL}"
  },
  "headers": [
    {
      "source": "/api/portal/public/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type"
        }
      ]
    }
  ]
}
