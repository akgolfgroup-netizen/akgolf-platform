generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  User              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model AchievementDefinition {
  id                String              @id
  key               String              @unique
  title             String
  description       String
  icon              String              @default("trophy")
  category          String
  threshold         Int                 @default(1)
  tierRequired      String              @default("ACADEMY")
  sortOrder         Int                 @default(0)
  createdAt         DateTime            @default(now())
  PlayerAchievement PlayerAchievement[]
}

model BlockedTime {
  id           String   @id
  instructorId String?
  startTime    DateTime
  endTime      DateTime
  reason       String?
  isRecurring  Boolean  @default(false)
  createdAt    DateTime @default(now())
}

model Booking {
  id                 String               @id
  studentId          String
  instructorId       String
  serviceTypeId      String
  locationId         String?
  resourceId         String?
  startTime          DateTime
  endTime            DateTime
  status             BookingStatus        @default(PENDING)
  paymentMethod      PaymentMethod        @default(NONE)
  paymentStatus      PaymentStatus        @default(PENDING)
  amount             Int                  @default(0)
  vatAmount          Int                  @default(0)
  stripePaymentId    String?
  vippsOrderId       String?
  invoiceId          String?
  isGroupBooking     Boolean              @default(false)
  studentNotes       String?
  adminNotes         String?
  cancelledAt        DateTime?
  cancelReason       String?
  reminderSentAt     DateTime?
  smsReminderSentAt  DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime
  Instructor         Instructor           @relation(fields: [instructorId], references: [id])
  Location           Location?            @relation(fields: [locationId], references: [id])
  Resource           Resource?            @relation(fields: [resourceId], references: [id])
  ServiceType        ServiceType          @relation(fields: [serviceTypeId], references: [id])
  User               User                 @relation(fields: [studentId], references: [id])
  CoachingSession    CoachingSession?
  GroupParticipant   GroupParticipant[]
  PaymentTransaction PaymentTransaction[]
  WaitlistEntry      WaitlistEntry[]

  @@index([instructorId])
  @@index([startTime])
  @@index([status])
  @@index([studentId])
}

model CoachingSession {
  id                String          @id
  bookingId         String          @unique
  studentId         String
  instructorId      String
  sessionDate       DateTime
  primaryFocus      String?
  secondaryFocus    String?
  techniquesCovered String[]
  drillsAssigned    String[]
  instructorNotes   String?
  studentNotes      String?
  videoUrls         String[]
  homework          String?
  progressRating    Int?
  followUpSent      Boolean         @default(false)
  followUpDate      DateTime?
  nextBookingId     String?
  retentionStatus   RetentionStatus @default(ACTIVE)
  aiSummary         String?
  aiKeyPoints       String[]        @default([])
  aiFocusAreas      String[]        @default([])
  aiActionItems     String[]        @default([])
  aiGeneratedAt     DateTime?
  uploadedFilePath  String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime
  notionPageId      String?
  Booking           Booking         @relation(fields: [bookingId], references: [id])
  Instructor        Instructor      @relation(fields: [instructorId], references: [id])
  User              User            @relation(fields: [studentId], references: [id])

  @@index([retentionStatus])
  @@index([studentId])
}

model CustomerPaymentPreference {
  id              String        @id
  userId          String        @unique
  customerType    CustomerType  @default(PRIVATE)
  preferredMethod PaymentMethod @default(NONE)
  companyName     String?
  orgNumber       String?
  invoiceEmail    String?
  invoiceAddress  String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime
  User            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmailTemplate {
  id          String   @id
  name        String   @unique
  subject     String
  htmlContent String
  variables   String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime
}

model Goal {
  id           String       @id
  userId       String
  title        String
  description  String?
  targetValue  Float?
  currentValue Float?       @default(0)
  unit         String?
  targetDate   DateTime?    @db.Date
  createdAt    DateTime     @default(now())
  updatedAt    DateTime
  status       GoalStatus   @default(ACTIVE)
  category     GoalCategory
  User         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model GroupParticipant {
  id        String   @id
  bookingId String
  name      String
  email     String
  phone     String?
  createdAt DateTime @default(now())
  Booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model HandicapEntry {
  id            String   @id
  userId        String
  date          DateTime
  handicapIndex Float
  source        String   @default("MANUAL")
  createdAt     DateTime @default(now())
  User          User     @relation(fields: [userId], references: [id])

  @@index([userId, date])
}

model Instructor {
  id                     String                   @id
  userId                 String                   @unique
  bio                    String?
  specialization         String?
  title                  String?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime
  Booking                Booking[]
  CoachingSession        CoachingSession[]
  User                   User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  InstructorAvailability InstructorAvailability[]
  ServiceType            ServiceType[]
  CommunicationLog       CommunicationLog[]
}

model InstructorAvailability {
  id           String     @id
  instructorId String
  dayOfWeek    Int
  startTime    String
  endTime      String
  Instructor   Instructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  @@unique([instructorId, dayOfWeek, startTime])
}

model Location {
  id        String     @id
  name      String
  address   String?
  createdAt DateTime   @default(now())
  updatedAt DateTime
  Booking   Booking[]
  Resource  Resource[]
}

model PaymentTransaction {
  id            String        @id
  bookingId     String
  paymentMethod PaymentMethod
  grossAmount   Int
  vatAmount     Int
  vatRate       Int
  feeAmount     Int           @default(0)
  netAmount     Int
  providerRef   String?
  status        PaymentStatus @default(PENDING)
  paidAt        DateTime?
  refundedAt    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime
  Booking       Booking       @relation(fields: [bookingId], references: [id])

  @@index([paidAt])
  @@index([paymentMethod])
  @@index([status])
}

model PeriodizationPeriod {
  id          String   @id
  studentId   String?
  periodType  String
  startDate   DateTime @db.Date
  endDate     DateTime @db.Date
  label       String?
  createdById String?
  createdAt   DateTime @default(now())
  User        User?    @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
}

model PlayerAchievement {
  id                      String                @id
  userId                  String
  unlockedAt              DateTime              @default(now())
  achievementDefinitionId String
  AchievementDefinition   AchievementDefinition @relation(fields: [achievementDefinitionId], references: [id], onDelete: Cascade)
  User                    User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementDefinitionId])
  @@index([userId])
}

model PlayerTournamentPlan {
  id           String     @id
  studentId    String
  tournamentId String
  planLevel    String
  goalType     String
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime
  isRegistered Boolean    @default(false)
  User         User       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  Tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([studentId, tournamentId])
  @@index([studentId])
}

model Resource {
  id         String    @id
  locationId String
  name       String
  type       String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime
  Booking    Booking[]
  Location   Location  @relation(fields: [locationId], references: [id], onDelete: Cascade)
}

model RoundStats {
  id                  String      @id
  userId              String
  date                DateTime
  courseName          String?
  source              RoundSource @default(MANUAL)
  totalScore          Int?
  scoreToPar          Int?
  par3Average         Float?
  par4Average         Float?
  par5Average         Float?
  eagleCount          Int?
  birdieCount         Int?
  parCount            Int?
  bogeyCount          Int?
  doublePlusCount     Int?
  bounceBackCount     Int?
  sgTotal             Float?
  sgOffTheTee         Float?
  sgApproach          Float?
  sgAroundTheGreen    Float?
  sgPutting           Float?
  drivingDistance     Float?
  fairwaysHit         Int?
  fairwaysTotal       Int?
  dispersion          Float?
  gir                 Int?
  girTotal            Int?
  proximityToHole     Float?
  approach100         Float?
  approach150         Float?
  approach200         Float?
  approach200Plus     Float?
  upAndDownMade       Int?
  upAndDownTotal      Int?
  sandSaveMade        Int?
  sandSaveTotal       Int?
  scrambleProximity   Float?
  totalPutts          Int?
  puttsPerGir         Float?
  onePuttCount        Int?
  threePuttCount      Int?
  makePct3ft          Float?
  makePct6ft          Float?
  makePct10ft         Float?
  speedRatio          Float?
  mentalProcessRating Int?
  notes               String?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime
  User                User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

model ServiceType {
  id             String          @id
  name           String
  description    String?
  category       ServiceCategory
  duration       Int
  price          Int
  maxStudents    Int             @default(1)
  isActive       Boolean         @default(true)
  isPublic       Boolean         @default(true)
  color          String?
  image          String?
  sortOrder      Int             @default(0)
  vatRate        Int             @default(0)
  bufferBefore   Int             @default(0)
  bufferAfter    Int             @default(15)
  minNoticeHours Int             @default(24)
  maxAdvanceDays Int             @default(60)
  allowStripe    Boolean         @default(true)
  allowVipps     Boolean         @default(true)
  allowInvoice   Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime
  Booking        Booking[]
  Instructor     Instructor[]
}

model Session {
  id           String   @id
  sessionToken String   @unique
  userId       String
  expires      DateTime
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TestDefinition {
  id           String       @id
  key          String       @unique
  name         String
  category     String
  skillLevel   String?
  description  String?
  instructions String?
  unit         String
  benchmarks   Json?
  sortOrder    Int          @default(0)
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime
  TestResult   TestResult[]
}

model TestResult {
  id               String         @id
  userId           String
  testDefinitionId String
  value            Float
  rawData          Json?
  date             DateTime       @default(now())
  notes            String?
  assessedBy       String?
  createdAt        DateTime       @default(now())
  TestDefinition   TestDefinition @relation(fields: [testDefinitionId], references: [id], onDelete: Cascade)
  User             User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([userId, testDefinitionId, date])
}

model Tournament {
  id                   String                 @id
  name                 String
  startDate            DateTime               @db.Date
  endDate              DateTime?              @db.Date
  level                String
  course               String?
  location             String?
  registrationDeadline DateTime?              @db.Date
  seriesUrl            String?
  externalUrl          String?
  createdById          String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime
  golfboxId            Int?                   @unique
  numberOfHoles        Int?
  series               String?
  source               String?
  sourceId             String?
  PlayerTournamentPlan PlayerTournamentPlan[]
  User                 User?                  @relation(fields: [createdById], references: [id])
  TournamentPrep       TournamentPrep[]

  @@unique([source, sourceId])
  @@index([startDate])
}

model TournamentPrep {
  id              String     @id
  tournamentId    String
  readinessScore  Int?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime
  checklist       Json?
  mentalPrepNotes String?
  userId          String
  warmupPlan      String?
  courseStrategy  Json?
  Tournament      Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  User            User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, userId])
  @@index([userId])
}

model TrainingLog {
  id                  String               @id
  userId              String
  planSessionId       String?
  date                DateTime
  completedAt         DateTime             @default(now())
  durationMinutes     Int?
  focusArea           String?
  exercises           Json                 @default("[]")
  notes               String?
  rating              Int?
  deviatedFromPlan    Boolean              @default(false)
  deviationReason     String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime
  TrainingPlanSession TrainingPlanSession? @relation(fields: [planSessionId], references: [id])
  User                User                 @relation(fields: [userId], references: [id])

  @@index([planSessionId])
  @@index([userId, date])
}

model TrainingPlan {
  id                                  String             @id
  studentId                           String
  createdById                         String
  title                               String
  description                         String?
  goals                               String?
  periodType                          String
  startDate                           DateTime           @db.Date
  endDate                             DateTime           @db.Date
  isActive                            Boolean            @default(true)
  aiGenerated                         Boolean            @default(false)
  createdAt                           DateTime           @default(now())
  updatedAt                           DateTime
  User_TrainingPlan_createdByIdToUser User               @relation("TrainingPlan_createdByIdToUser", fields: [createdById], references: [id])
  User_TrainingPlan_studentIdToUser   User               @relation("TrainingPlan_studentIdToUser", fields: [studentId], references: [id])
  TrainingPlanWeek                    TrainingPlanWeek[]

  @@index([studentId])
}

model TrainingPlanSession {
  id               String           @id
  weekId           String
  dayOfWeek        Int
  title            String
  description      String?
  durationMinutes  Int?
  focusArea        String?
  exercises        Json             @default("[]")
  sortOrder        Int              @default(0)
  createdAt        DateTime         @default(now())
  TrainingLog      TrainingLog[]
  TrainingPlanWeek TrainingPlanWeek @relation(fields: [weekId], references: [id], onDelete: Cascade)

  @@index([weekId])
}

model TrainingPlanWeek {
  id                  String                @id
  planId              String
  weekNumber          Int
  weekStart           DateTime              @db.Date
  focus               String?
  volumeLabel         String?
  createdAt           DateTime              @default(now())
  TrainingPlanSession TrainingPlanSession[]
  TrainingPlan        TrainingPlan          @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId])
}

model TrainingSubscription {
  id                    String   @id
  userId                String   @unique
  stripeSubscriptionId  String   @unique
  status                String
  currentPeriodStart    DateTime
  currentPeriodEnd      DateTime
  sessionsPerMonth      Int      @default(4)
  sessionsUsedThisMonth Int      @default(0)
  lastResetAt           DateTime @default(now())
  createdAt             DateTime @default(now())
  updatedAt             DateTime
  User                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                                          String                     @id
  supabaseId                                  String?                    @unique
  name                                        String?
  email                                       String?                    @unique
  emailVerified                               DateTime?
  image                                       String?
  phone                                       String?
  role                                        UserRole                   @default(STUDENT)
  calendarToken                               String?                    @unique
  googleCalendarTokens                        Json?
  googleCalendarId                            String?
  password                                    String?
  notionPageId                                String?
  createdAt                                   DateTime                   @default(now())
  updatedAt                                   DateTime
  isActive                                    Boolean                    @default(true)
  activeCoachingCustomer                      Boolean                    @default(false)
  videoStorageUsed                            BigInt                     @default(0)
  videoStorageLimit                           BigInt                     @default(2147483648)
  stripeCustomerId                            String?                    @unique
  stripeSubscriptionId                        String?
  subscriptionExpiresAt                       DateTime?
  subscriptionSource                          SubscriptionSource?
  subscriptionTier                            SubscriptionTier           @default(VISITOR)
  Account                                     Account[]
  Booking                                     Booking[]
  CoachingSession                             CoachingSession[]
  CustomerPaymentPreference                   CustomerPaymentPreference?
  Goal                                        Goal[]
  HandicapEntry                               HandicapEntry[]
  Instructor                                  Instructor?
  PeriodizationPeriod                         PeriodizationPeriod[]
  PlayerAchievement                           PlayerAchievement[]
  PlayerTournamentPlan                        PlayerTournamentPlan[]
  RoundStats                                  RoundStats[]
  Session                                     Session[]
  TestResult                                  TestResult[]
  Tournament                                  Tournament[]
  TournamentPrep                              TournamentPrep[]
  TrainingLog                                 TrainingLog[]
  TrainingPlan_TrainingPlan_createdByIdToUser TrainingPlan[]             @relation("TrainingPlan_createdByIdToUser")
  TrainingPlan_TrainingPlan_studentIdToUser   TrainingPlan[]             @relation("TrainingPlan_studentIdToUser")
  TrainingSubscription                        TrainingSubscription?
  WaitlistEntry                               WaitlistEntry[]
  UserSubscription                            UserSubscription[]
  CommunicationLog                            CommunicationLog[]
  Notification                                Notification[]
  AppSubscription                             AppSubscription[]
  SubscriptionQuota                           SubscriptionQuota?
  ExerciseDefinition                          ExerciseDefinition[]
  Message                                     Message[]
  SwingVideo                                  SwingVideo[]
  TrackmanSession                             TrackmanSession[]
  UserExerciseBank                            UserExerciseBank[]
  Conversation                                Conversation[]             @relation("ConversationParticipants")
  // Coach Hub relations
  assignedMessages                            UnifiedMessage[]           @relation("AssignedMessages")
  approvedResponses                           AIResponse[]               @relation("ApprovedResponses")
  learnings                                   AILearning[]               @relation("UserLearnings")
  pushSubscriptions                           PushSubscription[]         @relation("PushSubscriptions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model WaitlistEntry {
  id         String         @id
  bookingId  String
  studentId  String
  position   Int
  status     WaitlistStatus @default(WAITING)
  notifiedAt DateTime?
  expiresAt  DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime
  Booking    Booking        @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  User       User           @relation(fields: [studentId], references: [id])

  @@unique([bookingId, studentId])
  @@index([status])
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  NO_SHOW
  COMPLETED
}

enum CustomerType {
  PRIVATE
  BUSINESS
}

enum GoalCategory {
  SCORE
  PHYSICAL
  MENTAL
  TOURNAMENT
  PROCESS
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  PAUSED
}

enum PaymentMethod {
  STRIPE
  VIPPS
  INVOICE
  NONE
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  PARTIALLY_REFUNDED
  FAILED
}

enum RetentionStatus {
  ACTIVE
  AT_RISK
  CHURNED
}

enum RoundSource {
  MANUAL
  UPGAME
  ARCCOS
}

enum ServiceCategory {
  INDIVIDUAL
  GROUP
  VTG_COURSE
  SIMULATOR
  PLAYING_LESSON
}

enum SubscriptionSource {
  COACHING
  STRIPE
  MANUAL
}

enum SubscriptionTier {
  VISITOR
  ACADEMY
  STARTER
  PRO
  ELITE
}

enum UserRole {
  ADMIN
  INSTRUCTOR
  STUDENT
}

enum WaitlistStatus {
  WAITING
  NOTIFIED
  CONFIRMED
  EXPIRED
  CANCELLED
}

// ============================================================
// Nye enums for coaching, apper og kommunikasjon
// ============================================================

enum BillingType {
  RECURRING
  ONE_TIME
}

enum CoachingBookingType {
  SELF_BOOK
  DROP_IN
  FIXED
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  CANCELLED
  EXPIRED
  PAST_DUE
  CANCELED
  INCOMPLETE
}

enum CommunicationType {
  EMAIL
  SMS
  NOTE
  CALL
}

enum NotificationType {
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  BOOKING_REMINDER
  PLAN_GENERATED
  PLAN_READY
  ACHIEVEMENT_UNLOCKED
  TOURNAMENT_REMINDER
  COACHING_SUMMARY
  TRAINING_REMINDER
  GENERAL
}

enum CoachingSubscriptionTier {
  PERFORMANCE
  PERFORMANCE_PRO
  START
}

enum DashboardRole {
  ADMIN
  INSTRUCTOR
  VOLUNTEER
  CLUB_REP
}

enum ContentStatus {
  DRAFT
  REVIEW
  APPROVED
  PUBLISHED
  ARCHIVED
}

enum ContentType {
  SOME_POST
  NEWSLETTER
  ARTICLE
}

// Coach Hub enums
enum Channel {
  EMAIL
  INSTAGRAM
  MESSENGER
  WHATSAPP
  IMESSAGE
}

enum MessageStatus {
  PENDING
  AI_PROCESSING
  AI_READY
  APPROVED
  SENT
  FAILED
}

enum Direction {
  INBOUND
  OUTBOUND
}

// ============================================================
// Nye modeller for coaching, apper og kommunikasjon
// ============================================================

model CoachingPackage {
  id                 String              @id @default(cuid())
  name               String
  slug               String              @unique
  priceNok           Int
  vatRate            Int                 @default(25)
  billingType        BillingType
  bookingType        CoachingBookingType
  sessionsPerMonth   Int?
  sessionDurationMin Int                 @default(20)
  bookingWindowDays  Int?
  bookingWindowHours Int?
  maxBookingsPerWeek Int?
  slotsRequired      Int                 @default(1)
  description        String?
  features           String[]            @default([])
  sortOrder          Int                 @default(0)
  maxPlayersPerSlot  Int                 @default(1)
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  UserSubscription   UserSubscription[]
}

model UserSubscription {
  id                    String             @id @default(cuid())
  userId                String
  packageId             String
  status                SubscriptionStatus @default(ACTIVE)
  sessionsUsedThisMonth Int                @default(0)
  billingPeriodStart    DateTime?
  billingPeriodEnd      DateTime?
  stripeSubscriptionId  String?            @unique
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  user                  User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  package               CoachingPackage    @relation(fields: [packageId], references: [id])

  @@index([userId])
  @@index([status])
}

model CoachingAvailability {
  id          String   @id @default(cuid())
  dayOfWeek   Int
  startTime   String
  endTime     String
  isActive    Boolean  @default(true)
  reservedFor String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([dayOfWeek, isActive])
}

model CommunicationLog {
  id           String            @id @default(cuid())
  studentId    String
  instructorId String
  type         CommunicationType
  subject      String?
  content      String
  sentAt       DateTime          @default(now())
  student      User              @relation(fields: [studentId], references: [id], onDelete: Cascade)
  instructor   Instructor        @relation(fields: [instructorId], references: [id])

  @@index([studentId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  linkUrl   String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

model AppModule {
  id                  String            @id @default(cuid())
  slug                String            @unique
  name                String
  description         String?
  icon                String?
  monthlyPriceNok     Int               @default(0)
  yearlyPriceNok      Int?
  stripePriceId       String?
  stripeYearlyPriceId String?
  isActive            Boolean           @default(true)
  sortOrder           Int               @default(0)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  BundleItem          BundleItem[]
  AppSubscription     AppSubscription[]
}

model AppBundle {
  id                  String            @id @default(cuid())
  slug                String            @unique
  name                String
  description         String?
  monthlyPriceNok     Int               @default(0)
  yearlyPriceNok      Int?
  stripePriceId       String?
  stripeYearlyPriceId String?
  isActive            Boolean           @default(true)
  sortOrder           Int               @default(0)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  items               BundleItem[]
  AppSubscription     AppSubscription[]
}

model BundleItem {
  id       String    @id @default(cuid())
  bundleId String
  moduleId String
  bundle   AppBundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  module   AppModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([bundleId, moduleId])
}

model AppSubscription {
  id                   String     @id @default(cuid())
  userId               String
  moduleId             String?
  bundleId             String?
  status               String     @default("ACTIVE")
  stripeSubscriptionId String?    @unique
  cancelAtPeriodEnd    Boolean    @default(false)
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  user                 User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  module               AppModule? @relation(fields: [moduleId], references: [id])
  bundle               AppBundle? @relation(fields: [bundleId], references: [id])

  @@index([userId])
}

model DashboardAccess {
  id        String        @id @default(cuid())
  email     String        @unique
  role      DashboardRole
  name      String?
  active    Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model SubscriptionQuota {
  id                String                   @id @default(cuid())
  userId            String                   @unique
  subscriptionId    String?
  tier              CoachingSubscriptionTier
  sessionsAllowed   Int
  sessionsUsed      Int                      @default(0)
  periodStart       DateTime
  periodEnd         DateTime
  bookingWindowDays Int                      @default(7)
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  user              User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ContentItem {
  id           String        @id @default(cuid())
  type         ContentType
  status       ContentStatus @default(DRAFT)
  title        String
  slug         String?       @unique
  body         String
  bodyHtml     String?
  excerpt      String?
  platform     String?
  hashtags     String[]
  imageUrl     String?
  scheduledAt  DateTime?
  publishedAt  DateTime?
  aiGenerated  Boolean       @default(false)
  aiModel      String?
  notionPageId String?       @unique
  segment      String?
  createdBy    String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([scheduledAt])
  @@index([slug])
  @@index([type, status])
}

model Conversation {
  id           String    @id @default(cuid())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  Message      Message[]
  participants User[]    @relation("ConversationParticipants")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  readAt         DateTime?
  createdAt      DateTime     @default(now())
  Conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  User           User         @relation(fields: [senderId], references: [id])

  @@index([conversationId])
  @@index([senderId])
}

model ExerciseDefinition {
  id                 String             @id @default(cuid())
  name               String
  description        String?
  instructions       String?
  videoUrl           String?
  imageUrl           String?
  pyramid            String
  area               String
  lPhase             String?
  pPositionStart     String?
  pPositionEnd       String?
  equipment          String[]
  minDurationMinutes Int                @default(5)
  maxDurationMinutes Int                @default(30)
  difficulty         Int                @default(2)
  isPublic           Boolean            @default(false)
  isSystemDrill      Boolean            @default(false)
  createdById        String?
  tags               String[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  User               User?              @relation(fields: [createdById], references: [id])
  UserExerciseBank   UserExerciseBank[]

  @@index([area])
  @@index([isPublic])
  @@index([pyramid])
}

model SwingVideo {
  id           String   @id @default(cuid())
  userId       String
  url          String
  thumbnailUrl String?
  fileSize     BigInt
  title        String?
  coachNotes   String?
  aiAnalysis   Json?
  sessionId    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model TrackmanSession {
  id          String   @id @default(cuid())
  userId      String
  sessionDate DateTime
  club        String
  shots       Json
  averages    Json
  createdAt   DateTime @default(now())
  User        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sessionDate])
  @@index([userId])
}

model UserExerciseBank {
  id                 String             @id @default(cuid())
  userId             String
  exerciseId         String
  isFavorite         Boolean            @default(false)
  usageCount         Int                @default(0)
  lastUsedAt         DateTime?
  personalNotes      String?
  createdAt          DateTime           @default(now())
  ExerciseDefinition ExerciseDefinition @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  User               User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, exerciseId])
  @@index([userId])
}

// ============================================================================
// Coach Hub Models — Unified Inbox med AI-assistent
// ============================================================================

model UnifiedMessage {
  id           String        @id @default(cuid())
  channel      Channel
  direction    Direction
  externalId   String
  senderName   String
  senderHandle String
  subject      String?
  content      String        @db.Text
  receivedAt   DateTime
  status       MessageStatus @default(PENDING)
  assignedToId String?
  assignedTo   User?         @relation("AssignedMessages", fields: [assignedToId], references: [id])
  threadId     String?
  aiResponse   AIResponse?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([channel])
  @@index([status])
  @@index([assignedToId])
  @@index([receivedAt])
}

model AIResponse {
  id           String         @id @default(cuid())
  messageId    String         @unique
  message      UnifiedMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  draftContent String         @db.Text
  finalContent String?        @db.Text
  confidence   Float
  category     String
  modelUsed    String
  autoSent     Boolean        @default(false)
  wasEdited    Boolean        @default(false)
  editDiff     String?        @db.Text
  approvedById String?
  approvedBy   User?          @relation("ApprovedResponses", fields: [approvedById], references: [id])
  approvedAt   DateTime?
  createdAt    DateTime       @default(now())
}

model AILearning {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation("UserLearnings", fields: [userId], references: [id], onDelete: Cascade)
  category    String
  pattern     String    @db.Text
  response    String    @db.Text
  confidence  Float     @default(0.5)
  usageCount  Int       @default(0)
  lastUsed    DateTime?
  corrections Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([category])
}

model PushSubscription {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation("PushSubscriptions", fields: [userId], references: [id], onDelete: Cascade)
  endpoint   String
  p256dh     String
  auth       String
  deviceType String
  createdAt  DateTime @default(now())

  @@index([userId])
}
