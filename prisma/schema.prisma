generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Account {
  id                String  @id
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  User              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model AchievementDefinition {
  id                String              @id
  key               String              @unique
  title             String
  description       String
  icon              String              @default("trophy")
  category          String
  threshold         Int                 @default(1)
  tierRequired      String              @default("ACADEMY")
  sortOrder         Int                 @default(0)
  createdAt         DateTime            @default(now())
  PlayerAchievement PlayerAchievement[]
}

model Agent {
  id          String        @id
  name        String        @unique
  displayName String
  description String
  team        AgentTeam
  model       String
  tools       String[]
  skills      String[]      @default([])
  avatarPath  String
  status      AgentStatus   @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime
  AgentConfig AgentConfig[]
  AgentLog    AgentLog[]

  @@index([status])
  @@index([team])
}

model AgentConfig {
  id        String   @id @default(cuid())
  userId    String
  agentId   String
  isActive  Boolean  @default(true)
  scope     String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  Agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, agentId])
  @@index([userId])
  @@index([agentId])
}

model AgentLog {
  id        String   @id
  agentType String
  model     String
  status    String   @default("running")
  duration  Int?
  cost      Float?
  input     String?
  output    String?
  error     String?
  createdAt DateTime @default(now())
  agentId   String?
  Agent     Agent?   @relation(fields: [agentId], references: [id])

  @@index([agentId])
  @@index([agentType])
  @@index([createdAt])
  @@index([status])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model AppBundle {
  id                  String            @id
  slug                String            @unique
  name                String
  description         String?
  monthlyPriceNok     Int               @default(0)
  yearlyPriceNok      Int?
  stripePriceId       String?
  stripeYearlyPriceId String?
  isActive            Boolean           @default(true)
  sortOrder           Int               @default(0)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime
  AppSubscription     AppSubscription[]
  BundleItem          BundleItem[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model AppModule {
  id                  String            @id
  slug                String            @unique
  name                String
  description         String?
  icon                String?
  monthlyPriceNok     Int               @default(0)
  yearlyPriceNok      Int?
  stripePriceId       String?
  stripeYearlyPriceId String?
  isActive            Boolean           @default(true)
  sortOrder           Int               @default(0)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime
  AppSubscription     AppSubscription[]
  BundleItem          BundleItem[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model AppSubscription {
  id                   String     @id
  userId               String
  moduleId             String?
  bundleId             String?
  stripeSubscriptionId String?    @unique
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean    @default(false)
  createdAt            DateTime   @default(now())
  updatedAt            DateTime
  status               String     @default("ACTIVE")
  AppBundle            AppBundle? @relation(fields: [bundleId], references: [id])
  AppModule            AppModule? @relation(fields: [moduleId], references: [id])
  User                 User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model BlockedTime {
  id           String   @id
  instructorId String?
  startTime    DateTime
  endTime      DateTime
  reason       String?
  isRecurring  Boolean  @default(false)
  createdAt    DateTime @default(now())
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Booking {
  id                    String               @id
  studentId             String
  instructorId          String
  serviceTypeId         String
  locationId            String?
  resourceId            String?
  startTime             DateTime
  endTime               DateTime
  status                BookingStatus        @default(PENDING)
  paymentMethod         PaymentMethod        @default(NONE)
  paymentStatus         PaymentStatus        @default(PENDING)
  amount                Int                  @default(0)
  vatAmount             Int                  @default(0)
  stripePaymentId       String?
  vippsOrderId          String?
  invoiceId             String?
  isGroupBooking        Boolean              @default(false)
  studentNotes          String?
  adminNotes            String?
  cancelledAt           DateTime?
  cancelReason          String?
  reminderSentAt        DateTime?
  smsReminderSentAt     DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime
  facilityId            String?
  guestEmail            String?
  guestName             String?
  guestPhone            String?
  focusArea             FocusArea?
  playerNotes           String?
  googleCalendarEventId String?
  Facility              Facility?            @relation(fields: [facilityId], references: [id])
  Instructor            Instructor           @relation(fields: [instructorId], references: [id])
  Location              Location?            @relation(fields: [locationId], references: [id])
  Resource              Resource?            @relation(fields: [resourceId], references: [id])
  ServiceType           ServiceType          @relation(fields: [serviceTypeId], references: [id])
  User                  User                 @relation(fields: [studentId], references: [id])
  CoachingSession       CoachingSession?
  GroupParticipant      GroupParticipant[]
  PaymentTransaction    PaymentTransaction[]
  WaitlistEntry         WaitlistEntry[]

  @@index([instructorId])
  @@index([startTime])
  @@index([status])
  @@index([studentId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model BundleItem {
  id        String    @id
  bundleId  String
  moduleId  String
  AppBundle AppBundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  AppModule AppModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([bundleId, moduleId])
}

model CategoryRequirement {
  id          String @id @default(dbgenerated("(gen_random_uuid())::text"))
  testNumber  Int
  category    String
  gender      String
  requirement Float

  @@unique([testNumber, category, gender])
}

model CoachingAvailability {
  id          String   @id
  dayOfWeek   Int
  startTime   String
  endTime     String
  isActive    Boolean  @default(true)
  reservedFor String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime

  @@index([dayOfWeek, isActive])
}

model CoachingPackage {
  id                 String              @id
  name               String
  slug               String              @unique
  priceNok           Int
  billingType        BillingType
  bookingType        CoachingBookingType
  sessionsPerMonth   Int?
  sessionDurationMin Int                 @default(20)
  bookingWindowDays  Int?
  bookingWindowHours Int?
  maxPlayersPerSlot  Int                 @default(1)
  maxBookingsPerWeek Int?
  slotsRequired      Int                 @default(1)
  isActive           Boolean             @default(true)
  sortOrder          Int                 @default(0)
  description        String?
  features           String[]            @default([])
  createdAt          DateTime            @default(now())
  updatedAt          DateTime
  vatRate            Int                 @default(25)
  portalAccessDays   Int?
  instructorId       String?
  Instructor         Instructor?         @relation(fields: [instructorId], references: [id])
  UserSubscription   UserSubscription[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model CoachingSession {
  id                String          @id
  bookingId         String          @unique
  studentId         String
  instructorId      String
  sessionDate       DateTime
  primaryFocus      String?
  secondaryFocus    String?
  techniquesCovered String[]
  drillsAssigned    String[]
  instructorNotes   String?
  studentNotes      String?
  videoUrls         String[]
  homework          String?
  progressRating    Int?
  followUpSent      Boolean         @default(false)
  followUpDate      DateTime?
  nextBookingId     String?
  retentionStatus   RetentionStatus @default(ACTIVE)
  aiSummary         String?
  aiKeyPoints       String[]        @default([])
  aiFocusAreas      String[]        @default([])
  aiActionItems     String[]        @default([])
  aiGeneratedAt     DateTime?
  uploadedFilePath  String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime
  notionPageId      String?
  Booking           Booking         @relation(fields: [bookingId], references: [id])
  Instructor        Instructor      @relation(fields: [instructorId], references: [id])
  User              User            @relation(fields: [studentId], references: [id])

  @@index([retentionStatus])
  @@index([studentId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model CommunicationLog {
  id           String            @id
  studentId    String?
  instructorId String?
  type         CommunicationType @default(NOTE)
  subject      String?
  content      String?
  sentAt       DateTime          @default(now())
  body         String?
  channel      String?
  direction    String?
  metadata     Json?
  sentBy       String?
  status       String?
  Instructor   Instructor?       @relation(fields: [instructorId], references: [id])
  User         User?             @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model ContentItem {
  id           String        @id
  type         ContentType
  status       ContentStatus @default(DRAFT)
  title        String
  slug         String?       @unique
  body         String
  bodyHtml     String?
  excerpt      String?
  platform     String?
  hashtags     String[]
  imageUrl     String?
  scheduledAt  DateTime?
  publishedAt  DateTime?
  aiGenerated  Boolean       @default(false)
  aiModel      String?
  notionPageId String?       @unique
  segment      String?
  createdBy    String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime

  @@index([scheduledAt])
  @@index([slug])
  @@index([type, status])
}

model Conversation {
  id        String    @id
  createdAt DateTime  @default(now())
  updatedAt DateTime
  Message   Message[]
  User      User[]    @relation("ConversationParticipants")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model CustomerPaymentPreference {
  id              String        @id
  userId          String        @unique
  customerType    CustomerType  @default(PRIVATE)
  preferredMethod PaymentMethod @default(NONE)
  companyName     String?
  orgNumber       String?
  invoiceEmail    String?
  invoiceAddress  String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime
  User            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model DashboardAccess {
  id        String        @id
  email     String        @unique
  role      DashboardRole
  name      String?
  active    Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime
}

model DataGolfApproachSkill {
  id         String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  dgId       Int
  distance   String
  proxToHole Float
  sgApp      Float
  updatedAt  DateTime @default(now())

  @@unique([dgId, distance])
}

model DataGolfCache {
  id         String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  dgId       Int      @unique
  playerName String
  sgTotal    Float
  sgOtt      Float
  sgApp      Float
  sgArg      Float
  sgPutt     Float
  dgRank     Int?
  owgrRank   Int?
  updatedAt  DateTime @default(now())

  @@index([dgRank])
}

model EmailSequence {
  id                String              @id
  name              String
  description       String?
  trigger           String
  isActive          Boolean             @default(true)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime
  EmailSequenceStep EmailSequenceStep[]
}

model EmailSequenceExec {
  id                String            @id
  stepId            String
  studentId         String
  status            String            @default("pending")
  sentAt            DateTime?
  errorMsg          String?
  createdAt         DateTime          @default(now())
  EmailSequenceStep EmailSequenceStep @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@unique([stepId, studentId])
  @@index([status])
  @@index([studentId])
}

model EmailSequenceStep {
  id                String              @id
  sequenceId        String
  stepOrder         Int
  delayHours        Int                 @default(0)
  subject           String
  body              String
  bodyHtml          String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime
  EmailSequenceExec EmailSequenceExec[]
  EmailSequence     EmailSequence       @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  @@index([sequenceId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model EmailTemplate {
  id          String   @id
  name        String   @unique
  subject     String
  htmlContent String
  variables   String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model ExerciseDefinition {
  id                 String             @id
  name               String
  description        String?
  instructions       String?
  videoUrl           String?
  imageUrl           String?
  pyramid            String
  area               String
  lPhase             String?
  pPositionStart     String?
  pPositionEnd       String?
  equipment          String[]
  minDurationMinutes Int                @default(5)
  maxDurationMinutes Int                @default(30)
  difficulty         Int                @default(2)
  isPublic           Boolean            @default(false)
  isSystemDrill      Boolean            @default(false)
  createdById        String?
  tags               String[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime
  User               User?              @relation(fields: [createdById], references: [id])
  UserExerciseBank   UserExerciseBank[]

  @@index([area])
  @@index([isPublic])
  @@index([pyramid])
}

model GapOffer {
  id            String         @id
  instructorId  String
  serviceTypeId String
  startTime     DateTime
  endTime       DateTime
  discountPct   Int            @default(20)
  status        GapOfferStatus
  claimedBy     String?
  expiresAt     DateTime
  createdAt     DateTime       @default(now())

  @@index([expiresAt])
  @@index([instructorId])
  @@index([status])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Goal {
  id           String       @id
  userId       String
  title        String
  description  String?
  targetValue  Float?
  currentValue Float?       @default(0)
  unit         String?
  targetDate   DateTime?    @db.Date
  createdAt    DateTime     @default(now())
  updatedAt    DateTime
  status       GoalStatus   @default(ACTIVE)
  category     GoalCategory
  User         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model GroupParticipant {
  id        String   @id
  bookingId String
  name      String
  email     String
  phone     String?
  createdAt DateTime @default(now())
  Booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model HandicapEntry {
  id            String   @id
  userId        String
  date          DateTime
  handicapIndex Float
  source        String   @default("MANUAL")
  createdAt     DateTime @default(now())
  User          User     @relation(fields: [userId], references: [id])

  @@index([userId, date])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Instructor {
  id                         String                       @id
  userId                     String                       @unique
  bio                        String?
  specialization             String?
  title                      String?
  createdAt                  DateTime                     @default(now())
  updatedAt                  DateTime
  Booking                    Booking[]
  CoachingSession            CoachingSession[]
  CommunicationLog           CommunicationLog[]
  User                       User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  InstructorAvailability     InstructorAvailability[]
  InstructorDateAvailability InstructorDateAvailability[]
  InstructorFacilityDefault  InstructorFacilityDefault[]
  CoachingPackage            CoachingPackage[]
  ServiceType                ServiceType[]                @relation("InstructorToServiceType")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model InstructorAvailability {
  id           String     @id
  instructorId String
  dayOfWeek    Int
  startTime    String
  endTime      String
  Instructor   Instructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  @@unique([instructorId, dayOfWeek, startTime])
}

model InstructorDateAvailability {
  id           String     @id
  instructorId String
  date         DateTime
  startTime    String
  endTime      String
  locationId   String?
  createdAt    DateTime   @default(now())
  Instructor   Instructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  Location     Location?  @relation(fields: [locationId], references: [id])

  @@index([instructorId, date])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Location {
  id                         String                       @id
  name                       String
  address                    String?
  createdAt                  DateTime                     @default(now())
  updatedAt                  DateTime
  Booking                    Booking[]
  Facility                   Facility[]
  InstructorDateAvailability InstructorDateAvailability[]
  Resource                   Resource[]
}

model Message {
  id             String       @id
  conversationId String
  senderId       String
  content        String
  readAt         DateTime?
  createdAt      DateTime     @default(now())
  Conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  User           User         @relation(fields: [senderId], references: [id])

  @@index([conversationId])
  @@index([senderId])
}

model Notification {
  id        String           @id
  userId    String
  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)
  linkUrl   String?
  createdAt DateTime         @default(now())
  User      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model PaymentTransaction {
  id            String        @id
  bookingId     String
  paymentMethod PaymentMethod
  grossAmount   Int
  vatAmount     Int
  vatRate       Int
  feeAmount     Int           @default(0)
  netAmount     Int
  providerRef   String?
  status        PaymentStatus @default(PENDING)
  paidAt        DateTime?
  refundedAt    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime
  Booking       Booking       @relation(fields: [bookingId], references: [id])

  @@unique([providerRef])
  @@index([paidAt])
  @@index([paymentMethod])
  @@index([status])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model PeriodizationPeriod {
  id          String   @id
  studentId   String?
  periodType  String
  startDate   DateTime @db.Date
  endDate     DateTime @db.Date
  label       String?
  createdById String?
  createdAt   DateTime @default(now())
  User        User?    @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model PlayerAchievement {
  id                      String                @id
  userId                  String
  unlockedAt              DateTime              @default(now())
  achievementDefinitionId String
  AchievementDefinition   AchievementDefinition @relation(fields: [achievementDefinitionId], references: [id], onDelete: Cascade)
  User                    User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementDefinitionId])
  @@index([userId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model PlayerTournamentPlan {
  id           String     @id
  studentId    String
  tournamentId String
  planLevel    String
  goalType     String
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime
  isRegistered Boolean    @default(false)
  User         User       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  Tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([studentId, tournamentId])
  @@index([studentId])
}

model PricingRule {
  id            String          @id
  name          String
  ruleType      PricingRuleType
  adjustmentPct Int
  conditions    Json
  priority      Int             @default(0)
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime

  @@index([isActive])
}

model PromoCode {
  id             String           @id
  code           String           @unique
  discountType   DiscountType
  discountValue  Int
  maxUses        Int?
  usedCount      Int              @default(0)
  validFrom      DateTime?
  validUntil     DateTime?
  serviceTypeIds String[]
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  PromoCodeUsage PromoCodeUsage[]
}

model PromoCodeUsage {
  id             String    @id
  promoCodeId    String
  userId         String
  bookingId      String
  discountAmount Int
  createdAt      DateTime  @default(now())
  PromoCode      PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)

  @@unique([promoCodeId, userId])
  @@index([bookingId])
}

model PushSubscription {
  id         String   @id
  userId     String
  endpoint   String   @unique
  p256dh     String
  auth       String
  createdAt  DateTime @default(now())
  deviceType String?

  @@index([userId])
}

model RecurringBooking {
  id             String         @id
  studentId      String
  instructorId   String
  serviceTypeId  String
  dayOfWeek      Int
  startTime      String
  recurrenceType RecurrenceType
  startDate      DateTime       @db.Date
  endDate        DateTime?      @db.Date
  isActive       Boolean        @default(true)
  autoCharge     Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime

  @@index([instructorId])
  @@index([isActive])
  @@index([studentId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Resource {
  id         String    @id
  locationId String
  name       String
  type       String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime
  Booking    Booking[]
  Location   Location  @relation(fields: [locationId], references: [id], onDelete: Cascade)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model RoundStats {
  id                  String      @id
  userId              String
  date                DateTime
  courseName          String?
  source              RoundSource @default(MANUAL)
  totalScore          Int?
  scoreToPar          Int?
  par3Average         Float?
  par4Average         Float?
  par5Average         Float?
  eagleCount          Int?
  birdieCount         Int?
  parCount            Int?
  bogeyCount          Int?
  doublePlusCount     Int?
  bounceBackCount     Int?
  sgTotal             Float?
  sgOffTheTee         Float?
  sgApproach          Float?
  sgAroundTheGreen    Float?
  sgPutting           Float?
  drivingDistance     Float?
  fairwaysHit         Int?
  fairwaysTotal       Int?
  dispersion          Float?
  gir                 Int?
  girTotal            Int?
  proximityToHole     Float?
  approach100         Float?
  approach150         Float?
  approach200         Float?
