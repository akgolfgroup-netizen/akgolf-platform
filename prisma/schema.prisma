model AdminTask {
  id          String          @id
  title       String
  description String?
  division    AdminDivision
  status      AdminTaskStatus @default(TODO)
  priority    AdminPriority   @default(NORMAL)
  dueDate     DateTime?
  createdById String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime

  CreatedBy User @relation("AdminTaskCreator", fields: [createdById], references: [id])

  @@index([division])
  @@index([status])
}

enum AdminDivision {
  COACHING
  JUNIOR
  GFGK
}

enum AdminTaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum AdminPriority {
  URGENT
  IMPORTANT
  NORMAL
}
