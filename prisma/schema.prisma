  birdieCount         Int?
  parCount            Int?
  bogeyCount          Int?
  doublePlusCount     Int?
  bounceBackCount     Int?
  sgTotal             Float?
  sgOffTheTee         Float?
  sgApproach          Float?
  sgAroundTheGreen    Float?
  sgPutting           Float?
  drivingDistance     Float?
  fairwaysHit         Int?
  fairwaysTotal       Int?
  dispersion          Float?
  gir                 Int?
  girTotal            Int?
  proximityToHole     Float?
  approach100         Float?
  approach150         Float?
  approach200         Float?
  approach200Plus     Float?
  upAndDownMade       Int?
  upAndDownTotal      Int?
  sandSaveMade        Int?
