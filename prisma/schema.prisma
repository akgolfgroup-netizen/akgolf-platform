  @@index([assignedToId])
}

/// Coach Hub: AI-generated responses for unified inbox
model AIResponse {
  id           String         @id @default(cuid())
  messageId    String
  draftContent String
  finalContent String?
  confidence   Float?
  category     String?
  modelUsed    String?
  autoSent     Boolean        @default(false)
  wasEdited    Boolean        @default(false)
  approvedById String?
  approvedAt   DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  ApprovedBy   User?          @relation("ApprovedResponses", fields: [approvedById], references: [id])
  Message      UnifiedMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}

/// Coach Hub: AI learning patterns from user interactions
model AILearning {
  id         String    @id @default(cuid())
  userId     String
  category   String
  pattern    String
  response   String
  confidence Float     @default(0.5)
  usageCount Int       @default(0)
  lastUsed   DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  User       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, category])
}

model Facility {
  id                        String                      @id @default(cuid())
  locationId                String
  name                      String
  slug                      String                      @unique
  description               String?
  capacity                  Int?
  sortOrder                 Int                         @default(0)
  isActive                  Boolean                     @default(true)
  createdAt                 DateTime                    @default(now())
  updatedAt                 DateTime                    @updatedAt
  Booking                   Booking[]
  Location                  Location                    @relation(fields: [locationId], references: [id])
  FacilityActivity          FacilityActivity[]
  InstructorFacilityDefault InstructorFacilityDefault[]
  TrainingPlanSession       TrainingPlanSession[]
}

model FacilityActivity {
  id             String                 @id @default(cuid())
  facilityId     String
  title          String
  description    String?
  activityType   FacilityActivityType
  startTime      DateTime
  endTime        DateTime
  isRecurring    Boolean                @default(false)
  recurrenceRule String?
  createdById    String
  approvedById   String?
  status         FacilityActivityStatus @default(CONFIRMED)
  conflictNote   String?
  color          String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  ApprovedBy     User?                  @relation("FacilityActivityApprovedBy", fields: [approvedById], references: [id])
  CreatedBy      User                   @relation("FacilityActivityCreatedBy", fields: [createdById], references: [id])
  Facility       Facility               @relation(fields: [facilityId], references: [id])

  @@index([facilityId, startTime])
  @@index([status])
}

model InstructorFacilityDefault {
  id            String       @id @default(cuid())
  instructorId  String
  facilityId    String
  serviceTypeId String?
  priority      Int          @default(0)
  Facility      Facility     @relation(fields: [facilityId], references: [id])
  Instructor    Instructor   @relation(fields: [instructorId], references: [id])
  ServiceType   ServiceType? @relation(fields: [serviceTypeId], references: [id])

  @@unique([instructorId, facilityId, serviceTypeId])
}

model Course {
  id           String        @id
  name         String
  location     String?
  country      String        @default("NO")
  par          Int
  totalLength  Int?
  courseRating Float?
  slopeRating  Int?
  latitude     Float?
  longitude    Float?
  gpsData      Json?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime
  GameSession  GameSession[]
  Hole         Hole[]
  Round        Round[]

  @@index([name])
  @@index([country])
}

model Hole {
  id          String       @id
  courseId    String
  holeNumber  Int
  par         Int
  handicap    Int?
  lengthMeter Int
  teeColor    String       @default("yellow")
  latitude    Float?
  longitude   Float?
  greenLat    Float?
  greenLon    Float?
  strategy    Json?
  Course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  HoleResult  HoleResult[]
  Shot        Shot[]

  @@unique([courseId, holeNumber, teeColor])
  @@index([courseId])
}

model Round {
  id              String       @id
  userId          String
  courseId        String
  date            DateTime
  startTime       DateTime?
  endTime         DateTime?
  teeColor        String       @default("yellow")
  weather         String?
  windSpeed       Int?
  windDir         String?
  temperature     Int?
  totalScore      Int?
  scoreToPar      Int?
  sgTotal         Float?
  sgOffTheTee     Float?
  sgApproach      Float?
  sgShortGame     Float?
  sgPutting       Float?
  fairwaysHit     Int?
  fairwaysTotal   Int?
  girCount        Int?
  totalPutts      Int?
  decadeScore     Float?
  preRoutineScore Float?
  pressureLevel   Int?
  isComplete      Boolean      @default(false)
  source          String       @default("MANUAL")
  createdAt       DateTime     @default(now())
  updatedAt       DateTime
  gameSessionId   String?
  HoleResult      HoleResult[]
  Course          Course       @relation(fields: [courseId], references: [id])
  GameSession     GameSession? @relation(fields: [gameSessionId], references: [id])
  User            User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([courseId])
}

model GameSession {
  id          String       @id
  name        String?
  courseId    String
  date        DateTime
  teeColor    String       @default("yellow")
  format      GameFormat   @default(STROKEPLAY)
  createdById String
  joinCode    String       @unique
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime
  Players     GamePlayer[]
  Course      Course       @relation(fields: [courseId], references: [id])
  CreatedBy   User         @relation("GameSessionCreator", fields: [createdById], references: [id])
  Rounds      Round[]
}

model GamePlayer {
  id              String      @id
  gameSessionId   String
  userId          String
  displayName     String?
  playingHandicap Int?
  joinedAt        DateTime    @default(now())
  GameSession     GameSession @relation(fields: [gameSessionId], references: [id], onDelete: Cascade)
  User            User        @relation(fields: [userId], references: [id])

  @@unique([gameSessionId, userId])
}

model HoleResult {
  id                   String   @id
  roundId              String
  holeId               String
  holeNumber           Int
  par                  Int
  score                Int
  scoreToPar           Int
  putts                Int
  fairwayHit           Boolean?
  gir                  Boolean
  upAndDown            Boolean?
  sandSave             Boolean?
  penalty              Int      @default(0)
  sgTotal              Float?
  sgTee                Float?
  sgApproach           Float?
  sgShortGame          Float?
  sgPutting            Float?
  decadeTargetScore    Float?
  decadeActualVsTarget Float?
  strategyFollowed     Boolean?
  Hole                 Hole     @relation(fields: [holeId], references: [id])
  Round                Round    @relation(fields: [roundId], references: [id], onDelete: Cascade)
  Shot                 Shot[]

  @@unique([roundId, holeNumber])
  @@index([roundId])
}

model Shot {
  id                  String     @id
  holeResultId        String
  holeId              String
  shotNumber          Int
  fromLie             String
  fromDistance        Float
  toLie               String
  toDistance          Float
  club                String
  offline             Float?
  carryDistance       Float?
  totalDistance       Float?
  expectedBefore      Float
  expectedAfter       Float
  strokesGained       Float
  sgCategory          String
  targetDirection     String?
  actualDirection     String?
  decadeDecision      String?
  preRoutineCompleted Boolean?
  confidenceLevel     Int?
  trackmanShotId      String?    @unique
  Hole                Hole       @relation(fields: [holeId], references: [id])
  HoleResult          HoleResult @relation(fields: [holeResultId], references: [id], onDelete: Cascade)

  @@index([holeResultId])
  @@index([sgCategory])
}

model PlayerBag {
  id     String       @id
  userId String       @unique
  User   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  clubs  PlayerClub[]
}

model PlayerClub {
  id         String    @id
  bagId      String
  name       String
  brand      String?
  model      String?
  loft       Float?
  avgCarry   Float?
  avgTotal   Float?
  avgOffline Float?
  shotCount  Int       @default(0)
  sortOrder  Int       @default(0)
  PlayerBag  PlayerBag @relation(fields: [bagId], references: [id], onDelete: Cascade)

  @@index([bagId])
}

model Friendship {
  id        String           @id
  userId    String
  friendId  String
  status    FriendshipStatus @default(PENDING)
  createdAt DateTime         @default(now())
  Friend    User             @relation("FriendOf", fields: [friendId], references: [id], onDelete: Cascade)
  User      User             @relation("UserFriends", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
}

model Challenge {
  id           String                 @id
  createdById  String
  title        String
  type         ChallengeType
  metric       String
  startDate    DateTime
  endDate      DateTime
  isPublic     Boolean                @default(false)
  createdAt    DateTime               @default(now())
  Creator      User                   @relation(fields: [createdById], references: [id])
  Participants ChallengeParticipant[]
}

model ChallengeParticipant {
  id           String    @id
  challengeId  String
  userId       String
  currentValue Float?
  rank         Int?
  Challenge    Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  User         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([challengeId, userId])
}

model UserGolfId {
  id        String  @id
  userId    String  @unique
  golfboxId String?
  clubName  String?
  handicap  Float?
  User      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

