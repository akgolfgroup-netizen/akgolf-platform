# ============================================================
# AK Golf Website + Portal — Environment Variables
# ============================================================

# --- Supabase (Auth + Website DB) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- Portal Database (Prisma) ---
DATABASE_URL=postgresql://user:password@host:5432/akgolf_booking

# --- Stripe (Payments) ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_PRICE_BASIS=price_xxx
STRIPE_PRICE_STANDARD=price_xxx
STRIPE_PRICE_PREMIUM=price_xxx

# --- Anthropic Claude (AI) ---
ANTHROPIC_API_KEY=sk-ant-xxx

# --- Resend (Email) ---
# 1. Opprett konto på https://resend.com
# 2. Verifiser domene (akgolf.no) i Resend-dashboardet
# 3. Generer API key med 'Sending' tillatelser
# 4. Opprett e-postadresse: noreply@akgolf.no (for system-e-post)
# 5. Kontakt-e-post: post@akgolf.no (mottar henvendelser fra skjemaer)
RESEND_API_KEY=re_your_api_key_here
CONTACT_EMAIL=post@akgolf.no
FROM_EMAIL=noreply@akgolf.no

# --- Twilio (SMS, portal) ---
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+47xxxxxxxx

# --- Google OAuth (via Supabase Auth provider) ---
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# --- DataGolf API (portal) ---
DATAGOLF_API_KEY=your_api_key

# --- Notion ---
NOTION_API_KEY=ntn_your_api_key_here
NOTION_BRAND_GUIDE_DB_ID=caa4fdd02e2f4865aaeef4ad923be925

# --- Formspree ---
NEXT_PUBLIC_FORMSPREE_ID=your_form_id_here
