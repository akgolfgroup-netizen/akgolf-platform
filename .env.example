# ============================================================
# AK Golf Website + Portal — Environment Variables
# ============================================================

# --- Supabase (Auth + Website DB) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- Portal Database (Prisma) ---
DATABASE_URL=postgresql://user:password@host:5432/akgolf_booking

# --- Stripe (Payments) ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Coaching Abonnementer (REQUIRED for booking system)
STRIPE_PRICE_PERFORMANCE_PRO=price_xxx    # Performance Pro - 2000 kr/mnd (4 sesjoner)
STRIPE_PRICE_PERFORMANCE=price_xxx         # Performance - 1600 kr/mnd (2 sesjoner)
STRIPE_PRICE_START=price_xxx               # Start Onboarding - 3000 kr (engangskjøp)
STRIPE_PRICE_FOUNDATION_TEST=price_xxx     # Foundation Test - 995 kr (engangskjøp)

# AI Treningsplaner (valgfritt)
STRIPE_PRICE_BASIS=price_xxx        # AI Treningsplan Basis - 199 kr
STRIPE_PRICE_STANDARD=price_xxx     # AI Treningsplan Standard - 699 kr/sesong
STRIPE_PRICE_PREMIUM=price_xxx      # AI Treningsplan Premium - 1999 kr/år

# Coaching enkelttimer (valgfritt - alternativ til Vipps)
STRIPE_PRICE_COACH_INDIVIDUAL=price_xxx   # Individuell coaching - 995 kr
STRIPE_PRICE_COACH_PLAYING=price_xxx      # Playing lesson - 1795 kr
STRIPE_PRICE_COACH_GROUP=price_xxx        # Gruppetrening - 495 kr
STRIPE_PRICE_COACH_SIMULATOR=price_xxx    # Simulator-time - 595 kr

# --- Anthropic Claude (AI) ---
ANTHROPIC_API_KEY=sk-ant-xxx

# --- Resend (Email) ---
# 1. Opprett konto på https://resend.com
# 2. Verifiser domene (akgolf.no) i Resend-dashboardet
# 3. Generer API key med 'Sending' tillatelser
# 4. Opprett e-postadresse: noreply@akgolf.no (for system-e-post)
# 5. Kontakt-e-post: post@akgolf.no (mottar henvendelser fra skjemaer)
RESEND_API_KEY=re_your_api_key_here
CONTACT_EMAIL=post@akgolf.no
FROM_EMAIL=noreply@akgolf.no

# --- Twilio (SMS, portal) ---
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+47xxxxxxxx

# --- Google OAuth (via Supabase Auth provider) ---
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# --- DataGolf API (portal) ---
DATAGOLF_API_KEY=your_api_key

# --- Notion ---
NOTION_API_KEY=ntn_your_api_key_here
NOTION_BRAND_GUIDE_DB_ID=caa4fdd02e2f4865aaeef4ad923be925

# --- Cron (for påminnelser) ---
# Generer en sterk secret for å beskytte cron-endepunkter
CRON_SECRET=your_random_secret_here_at_least_32_chars

# --- App URL ---
# Viktig for webhooks og lenker i e-poster
NEXT_PUBLIC_APP_URL=https://akgolf.no
