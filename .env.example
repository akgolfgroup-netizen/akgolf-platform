# ============================================================
# AK Golf Website + Portal — Environment Variables
# ============================================================

# --- Supabase (Auth + Website DB) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- Portal Database (Prisma) ---
DATABASE_URL=postgresql://user:password@host:5432/akgolf_booking

# --- Stripe (Payments) ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Coaching-pakker (abonnement)
STRIPE_PRICE_PERFORMANCE=price_xxx         # Performance - 1600 kr/mnd (2 sesjoner)
STRIPE_PRICE_PERFORMANCE_PRO=price_xxx     # Performance Pro - 2000 kr/mnd (4 sesjoner)
STRIPE_PRICE_JUNIOR_ACADEMY=price_xxx      # Junior Academy - 2500 kr/mnd
STRIPE_PRICE_JUNIOR_ELITE=price_xxx        # Junior Elite - 2500 kr/mnd (8 sesjoner)

# Flex-pakker (engangskjøp)
STRIPE_PRICE_FLEX50=price_xxx              # Flex 50 - 1500 kr (50 min)
STRIPE_PRICE_FLEX90=price_xxx              # Flex 90 - 2500 kr (90 min)

# --- Anthropic Claude (AI) ---
ANTHROPIC_API_KEY=sk-ant-xxx

# --- Resend (Email) ---
# 1. Opprett konto på https://resend.com
# 2. Verifiser domene (akgolf.no) i Resend-dashboardet
# 3. Generer API key med 'Sending' tillatelser
# 4. Opprett e-postadresse: noreply@akgolf.no (for system-e-post)
# 5. Kontakt-e-post: post@akgolf.no (mottar henvendelser fra skjemaer)
RESEND_API_KEY=re_your_api_key_here
CONTACT_EMAIL=post@akgolf.no
FROM_EMAIL=noreply@akgolf.no

# --- Twilio (SMS, portal) ---
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+47xxxxxxxx

# --- Google OAuth / Calendar ---
# Brukes både for Supabase Auth (Google login) og Google Calendar sync
# For Calendar sync må du også aktivere Google Calendar API i Google Cloud Console
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
# GOOGLE_REDIRECT_URI=https://akgolf.no/api/portal/calendar/google/callback  # Optional, defaults to NEXT_PUBLIC_APP_URL

# --- DataGolf API (portal) ---
DATAGOLF_API_KEY=your_api_key

# --- Notion ---
NOTION_API_KEY=ntn_your_api_key_here
NOTION_BRAND_GUIDE_DB_ID=caa4fdd02e2f4865aaeef4ad923be925

# --- Push-notifikasjoner (Web Push / VAPID) ---
# Generer med: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:post@akgolf.no

# --- Microsoft Clarity (Analytics, valgfri) ---
# NEXT_PUBLIC_CLARITY_PROJECT_ID=your_clarity_project_id

# --- Integrasjon-hemmeligheter ---
# Beskytter eksterne integrasjoner (Gmail sync, turneringsimport)
INTEGRATION_SECRET=your_integration_secret_here
TOURNAMENT_SYNC_SECRET=your_tournament_sync_secret_here

# --- Cron (for påminnelser) ---
# Generer en sterk secret for å beskytte cron-endepunkter
CRON_SECRET=your_random_secret_here_at_least_32_chars

# --- App URL ---
# Viktig for webhooks og lenker i e-poster
NEXT_PUBLIC_APP_URL=https://akgolf.no

# --- Vedlikeholdsmodus ---
# Sett til "true" for å aktivere vedlikeholdsmodus på hele siten
# Bruk ?bypass=DIN_SECRET_KEY for å omgå vedlikeholdsmodus
MAINTENANCE_MODE=false
MAINTENANCE_BYPASS_KEY=your_secret_bypass_key_here
MAINTENANCE_EXPECTED_DURATION="Ca. 2 timer"
MAINTENANCE_MESSAGE="Vi oppgraderer systemene for å gi deg en bedre opplevelse"
