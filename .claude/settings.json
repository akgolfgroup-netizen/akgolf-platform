{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git stash:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git checkout *)",
      "Bash(git branch:*)",
      "Bash(gh pr *)",
      "Bash(gh issue *)",
      "Bash(npm run *)",
      "Bash(npm install *)",
      "Bash(npm uninstall *)",
      "Bash(npx prisma *)",
      "Bash(npx tsc *)",
      "Bash(npx eslint *)",
      "Bash(npx next *)",
      "Bash(node *)",
      "Bash(ls *)",
      "Bash(ps *)",
      "Bash(lsof *)",
      "Bash(kill *)",
      "Bash(pkill *)",
      "Bash(curl -I *)",
      "Bash(curl -s *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(mkdir *)",
      "Bash(rm -rf .next)",
      "Bash(rm -rf node_modules)",
      "Bash(mv *)",
      "Bash(cp *)",
      "Bash(touch *)",
      "Bash(chmod *)",
      "Bash(pwd)",
      "Bash(echo *)",
      "Bash(printf *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(tr *)",
      "Bash(cut *)",
      "Bash(jq *)",
      "Bash(date)",
      "Bash(whoami)",
      "Bash(uname *)",
      "Bash(which *)",
      "Bash(open *)",
      "Bash(claude *)",
      "Bash(python3 *)",
      "Read(./**)",
      "Edit(./**)",
      "Write(./**)",
      "Glob(./**)",
      "Grep(./**)",
      "WebSearch",
      "WebFetch",
      "Agent",
      "AskUserQuestion",
      "ExitPlanMode"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./.ssh/**)",
      "Read(./.aws/**)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.claude.json)",
      "Bash(curl *|*sh*)",
      "Bash(curl *|*bash*)",
      "Bash(wget *|*sh*)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf /*)",
      "Bash(sudo *)",
      "Bash(su *)",
      "Bash(chsh *)",
      "Bash(passwd *)",
      "Bash(dd *)",
      "Bash(mkfs *)",
      "Bash(fdisk *)"
    ],
    "ask": [
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "Bash(git rebase *)",
      "Bash(git cherry-pick *)",
      "Bash(rm -rf *)",
      "Bash(rm -f *)",
      "Bash(mv * *)"
    ]
  },
  "env": {
    "NEXT_TELEMETRY_DISABLED": "1",
    "NODE_ENV": "development"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(rm -rf *)",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/block-destructive.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "if": "Edit(*.tsx)|Edit(*.ts)|Write(*.tsx)|Write(*.ts)",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/check-design-tokens.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/load-worklog.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "attribution": {
    "commit": "Generated with Claude Code\n\nCo-Authored-By: Claude <noreply@anthropic.com>",
    "pr": "Generated with Claude Code"
  }
}
